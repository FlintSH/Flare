# Postgres Configuration
# Format: postgresql://USERNAME:PASSWORD@HOST:PORT/DATABASE?schema=SCHEMA
DATABASE_URL="postgresql://flare:flarepassword@localhost:5432/flare?schema=public"

# The base URL of your Flare instance
NEXTAUTH_URL="http://localhost:3000"

# A secret key used to encrypt session data, can be anything.
NEXTAUTH_SECRET="your-secret-key-here"

# OAuth Provider Configuration (Optional - enable SSO by providing these)
# Google OAuth
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# GitHub OAuth
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""

# Azure AD OAuth
AZURE_AD_CLIENT_ID=""
AZURE_AD_CLIENT_SECRET=""
AZURE_AD_TENANT_ID=""

# SAML Configuration (Optional - for enterprise SSO)
SAML_ISSUER=""
SAML_CALLBACK_URL=""
SAML_ENTRY_POINT=""
SAML_CERT=""